# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Meta Ads API ──────────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ── Meta Ad Library API (competitor analysis — public, no user OAuth) ─────────
# 1. developers.facebook.com → your app → Add Product → "Ad Library API"
# 2. Tools → Graph API Explorer → generate token with scope: ads_read
# 3. Convert to long-lived token (60 days) via /oauth/access_token endpoint
# 4. For production: create a System User in Business Manager and issue a never-expiring token
META_LIBRARY_TOKEN=your_meta_library_access_token

# ── Apify (preferred competitor data source — no Meta identity verification) ──
# 1. Sign up at apify.com → Settings → Integrations → API tokens
# 2. Free tier includes $5/mo credit (~5000 ads)
# Actor used: curious_coder/facebook-ads-library-scraper
APIFY_TOKEN=your_apify_api_token

# ── Google Ads API ────────────────────────────────────────────────────────────
# OAuth credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Developer token: https://ads.google.com/home/tools/manager-accounts/
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
